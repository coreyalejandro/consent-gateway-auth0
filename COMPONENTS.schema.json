{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://consent-gateway.local/schemas/component-inventory.schema.json",
  "title": "Consent Gateway component inventory",
  "type": "object",
  "required": ["version", "components"],
  "properties": {
    "version": { "type": "string" },
    "components": {
      "type": "array",
      "items": { "$ref": "#/$defs/component" }
    }
  },
  "$defs": {
    "component": {
      "type": "object",
      "required": [
        "id",
        "service",
        "operation",
        "risk",
        "requiredScopes",
        "audience",
        "connection"
      ],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "description": "Stable tool / action id" },
        "service": { "type": "string" },
        "operation": { "type": "string" },
        "risk": { "type": "string", "enum": ["LOW", "MEDIUM", "HIGH"] },
        "requiredScopes": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "audience": {
          "type": "string",
          "description": "Resource server / API audience for the provider access token"
        },
        "connection": {
          "type": "string",
          "minLength": 1,
          "description": "Auth0 authentication connection name (e.g. google-oauth2)"
        },
        "description": { "type": "string" }
      }
    }
  }
}
