# Auth0 (required for login + Token Vault)
AUTH0_SECRET=
AUTH0_BASE_URL=http://localhost:3000
AUTH0_ISSUER_BASE_URL=https://YOUR_TENANT.auth0.com
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=

# Optional: default API audience for Token Vault / Google
# AUTH0_AUDIENCE=https://www.googleapis.com/auth/calendar.readonly
