# Auth0 Next.js SDK v4 — see https://github.com/auth0/nextjs-auth0/blob/main/V4_MIGRATION_GUIDE.md
APP_BASE_URL=http://localhost:3000
AUTH0_DOMAIN=YOUR_TENANT.us.auth0.com
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_SECRET=

# Legacy alias (optional): full issuer URL — otherwise derived as https://AUTH0_DOMAIN
# AUTH0_ISSUER_BASE_URL=https://YOUR_TENANT.us.auth0.com

# Subject access token audience (Auth0 API identifier) for RFC 8693 token exchange input
AUTH0_SUBJECT_TOKEN_AUDIENCE=

# Token exchange client (confidential client enabled for token exchange)
AUTH0_TOKEN_VAULT_CLIENT_ID=
AUTH0_TOKEN_VAULT_CLIENT_SECRET=
