# Auth0 (required for login)
AUTH0_SECRET=
AUTH0_BASE_URL=http://localhost:3000
AUTH0_ISSUER_BASE_URL=https://YOUR_TENANT.auth0.com
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=

# Subject token for RFC 8693 token exchange (Auth0 API identifier — user access token)
AUTH0_SUBJECT_TOKEN_AUDIENCE=

# Token exchange client (confidential client enabled for token exchange / Token Vault)
AUTH0_TOKEN_VAULT_CLIENT_ID=
AUTH0_TOKEN_VAULT_CLIENT_SECRET=
